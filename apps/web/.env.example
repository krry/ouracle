# Production API (default)
VITE_OURACLE_BASE_URL=https://api.ouracle.kerry.ink

# Local dev: point at the local API server instead.
# Run the API on port 3737 with BETTER_AUTH_URL=http://localhost:3737 in api/.env
# Then set this to:
# VITE_OURACLE_BASE_URL=http://localhost:3737
#
# OAuth local testing notes:
# - Google/GitHub: register http://localhost:3737/api/auth/callback/google (or /github)
#   as an authorized redirect URI in the provider's dashboard.
# - Apple: requires HTTPS + registered domain — cannot be tested at localhost.
#   Use ngrok or a dev tunnel and register the tunnel URL with Apple.
